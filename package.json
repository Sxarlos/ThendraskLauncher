{
  "name": "thendrask-launcher",
  "productName": "Thendrask Launcher",
  "version": "0.5.3",
  "description": "A Minecraft launcher with modpack browsing, friends presence, and automatic updates",
  "main": "./out/main/index.js",
  "author": "Sxarlos",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint src",
    "test": "vitest run",
    "package": "electron-vite build && electron-builder"
  },
  "build": {
    "appId": "com.enderlauncher.app",
    "productName": "Thendrask Launcher",
    "extraMetadata": {
      "description": "Thendrask Launcher"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Sxarlos",
        "repo": "ThendraskLauncher",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Thendrask Launcher",
      "artifactName": "Thendrask-Launcher-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "category": "public.app-category.games",
      "artifactName": "Thendrask-Launcher-${version}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "Thendrask-Launcher-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "category": "Game",
      "maintainer": "Sxarlos",
      "synopsis": "A Minecraft launcher with modpack browsing, friends presence, and automatic updates"
    }
  },
  "dependencies": {
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "discord-rpc": "^4.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "minecraft-launcher-core": "^3.18.1",
    "minecraft-server-util": "^5.4.4",
    "mqtt": "^5.15.1",
    "msmc": "^5.0.5",
    "rcon-client": "^4.2.5",
    "skinview3d": "^3.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.11",
    "vitest": "^4.1.9",
    "zustand": "^5.0.2"
  }
}
